# ============================================
# Hyperscale LCM 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际环境修改值
# cp .env.example .env

# ============================================
# 数据库配置
# ============================================
DB_USERNAME=lcm_user
DB_PASSWORD=your_secure_password_here
DB_URL=jdbc:postgresql://localhost:5432/lcm_db

# ============================================
# gRPC SSL 证书配置
# ============================================
GRPC_CERT_PATH=./certs/server.pem
GRPC_KEY_PATH=./certs/server-pkcs8.key
GRPC_TRUSTSTORE_PATH=./certs/truststore.jks
GRPC_TRUSTSTORE_PASSWORD=changeit

# ============================================
# 中间件配置
# ============================================
REDIS_URL=redis://localhost:6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================
# CORS 配置 (生产环境请修改)
# ============================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# Satellite Agent 配置
# ============================================
CORE_ADDRESS=localhost:9000
CERT_DIR=./certs

# ============================================
# 生产环境额外配置
# ============================================
# ALLOWED_ORIGINS=https://lcm.example.com
# HTTP_CERT_PATH=/etc/ssl/certs/server.crt
# HTTP_KEY_PATH=/etc/ssl/private/server.key
